"offset": Vector2(13840, 760),
"signalValue": "HideKoda"
},
&"3_4": {
"link": &"1_39",
"offset": Vector2(14950.186, 823.9955),
"signalValue": "ShowKoda"
}
}
characters = "res://VN/characters.tres"
